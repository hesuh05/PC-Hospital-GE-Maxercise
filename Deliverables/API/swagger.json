{
  "openapi": "3.0.0",
  "info": {
    "title": "API Gerencia Hospital",
    "version": "1.0.0",
    "description": "Documentación interactiva de la API del Hospital"
  },
  "servers": [
    {
      "url": "/"
    }
  ],
  "tags": [
    {
      "name": "Mongo Seeder",
      "description": "Endpoints para poblar y limpiar colecciones MongoDB de pruebas."
    },
    {
      "name": "Mongo CRUD",
      "description": "Endpoints CRUD manuales para documentos MongoDB."
    },
    {
      "name": "Quejas y Sugerencias",
      "description": "Endpoints de quejas y sugerencias."
    }
  ],
  "paths": {
    "/gerencia/mongo/quejas-sugerencias/poblar": {
      "post": {
        "summary": "Poblar quejas y sugerencias masivamente (Mongo Seeder)",
        "tags": ["Mongo Seeder"],
        "description": "Genera datos aleatorios de quejas y sugerencias directamente en MongoDB, utilizando el endpoint de poblado de colección.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "cantidad": { "type": "integer", "example": 15 },
                  "tipo": { "type": "string", "enum": ["queja", "sugerencia"], "nullable": true, "example": null },
                  "prioridad": { "type": "string", "enum": ["baja", "media", "alta", "urgente"], "nullable": true, "example": null },
                  "estatus": { "type": "string", "enum": ["registrada", "en_revision", "en_proceso", "atendida", "cerrada", "cancelada"], "nullable": true, "example": null },
                  "medio_recepcion": { "type": "string", "enum": ["buzon", "web", "telefono", "presencial", "app"], "nullable": true, "example": null },
                  "con_seguimiento": { "type": "string", "enum": ["si", "no", "aleatorio"], "nullable": true, "example": "aleatorio" },
                  "area_id": { "type": "integer", "nullable": true, "example": null, "description": "ID del área para restringir la generación." },
                  "departamento_id": { "type": "integer", "nullable": true, "example": null, "description": "ID del departamento para restringir la generación." },
                  "personal_id": { "type": "integer", "nullable": true, "example": null, "description": "ID del empleado sobre el cual recaerá la queja/sugerencia." }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Registros generados con éxito" },
          "400": { "description": "Incongruencia en los parámetros." },
          "404": { "description": "Área, Departamento o Personal no encontrado." },
          "500": { "description": "Error interno del servidor" }
        }
      }
    },
    "/gerencia/mongo/quejas-sugerencias/limpiar": {
      "delete": {
        "summary": "Vaciar la colección de quejas y sugerencias (Mongo Seeder)",
        "tags": ["Mongo Seeder"],
        "description": "Elimina todos los documentos de la colección de Quejas y Sugerencias en MongoDB.",
        "responses": {
          "200": {
            "description": "Colección limpiada exitosamente.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": { "type": "string", "example": "Colección de Quejas y Sugerencias limpiada exitosamente." }
                  }
                }
              }
            }
          },
          "500": {
            "description": "Error interno del servidor.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": { "type": "string", "example": "Error interno al intentar vaciar la colección." }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/gerencia/pacientes": {
      "get": {
        "summary": "Obtener lista de pacientes",
        "tags": ["Pacientes"],
        "responses": {
          "200": { "description": "Lista obtenida correctamente" }
        }
      }
    },
    "/gerencia/pacientes/limpiar": {
      "delete": {
        "summary": "Vaciar tabla de pacientes (Truncate)",
        "tags": ["Pacientes"],
        "responses": {
          "200": { "description": "Tabla limpiada" }
        }
      }
    },
    "/gerencia/pacientes/poblar": {
      "post": {
        "summary": "Poblar pacientes mediante procedimiento almacenado",
        "tags": ["Pacientes"],
        "description": "Llama al SP sp_poblar_pacientes con 11 parámetros configurables para generar datos de prueba.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "p_cantidad": { "type": "integer", "default": 10, "description": "Cantidad de registros a generar" },
                  "p_c_genero": { "type": "string", "enum": ["H", "M"], "default": "H" },
                  "p_edad_minima": { "type": "integer", "default": 18 },
                  "p_edad_maxima": { "type": "integer", "default": 99 },
                  "p_estatus_vida": { "type": "string", "enum": ["Vivo", "Finado"], "default": "Vivo" },
                  "p_modo_estatus_medico": { "type": "integer", "default": -1, "description": "-1 para aleatorio" },
                  "p_estatus_medico": { "type": "string", "default": "Estable" },
                  "p_tipo_edad": { "type": "string", "default": "adulto" },
                  "p_modo_situacion_medica": { "type": "integer", "default": -1 },
                  "p_situacion_medica": { "type": "string", "nullable": true, "default": null },
                  "p_modo_titulo": { "type": "string", "nullable": true, "default": null }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Procedimiento ejecutado con éxito" },
          "500": { "description": "Error al ejecutar el procedimiento" }
        }
      }
    },
    "/gerencia/patologias": {
      "get": {
        "summary": "Listar todas las patologías",
        "tags": ["Patologías"],
        "responses": { "200": { "description": "OK" } }
      },
      "post": {
        "summary": "Crear nueva patología",
        "tags": ["Patologías"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["nombre", "nombre_cientifico", "fecha_clasificacion"],
                "properties": {
                  "nombre": { "type": "string", "example": "Diabetes" },
                  "nombre_cientifico": { "type": "string", "example": "Diabetes Mellitus" },
                  "nombre_comun": { "type": "string", "example": "Azúcar" },
                  "descripcion": { "type": "string", "example": "Trastorno metabólico crónico" },
                  "fecha_clasificacion": { "type": "string", "format": "date", "example": "2026-03-10" },
                  "tipos_ids": { "type": "array", "items": { "type": "integer" }, "example": [1, 2] }
                }
              }
            }
          }
        },
        "responses": { "201": { "description": "Creada" } }
      }
    },
    "/gerencia/patologias/{id}": {
      "put": {
        "summary": "Actualizar una patología",
        "tags": ["Patologías"],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "nombre": { "type": "string", "example": "Diabetes" },
                  "nombre_cientifico": { "type": "string", "example": "Diabetes Mellitus" },
                  "nombre_comun": { "type": "string", "example": "Azúcar" },
                  "descripcion": { "type": "string", "example": "Trastorno metabólico crónico" }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "Actualizada" } }
      },
      "delete": {
        "summary": "Eliminar una patología",
        "tags": ["Patologías"],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "responses": { "200": { "description": "Eliminada" } }
      }
    },
    "/gerencia/organos": {
      "get": { "summary": "Listar órganos", "tags": ["Orgános"], "responses": { "200": { "description": "OK" } } },
      "post": {
        "summary": "Crear órgano",
        "tags": ["Orgános"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["Nombre", "Sistema_Aparato", "Stock", "Fecha_Registro"],
                "properties": {
                  "Nombre": { "type": "string", "example": "Corazón" },
                  "Sistema_Aparato": { "type": "string", "example": "Circulatorio" },
                  "Requisitos": { "type": "string", "example": "Condición A" },
                  "Stock": { "type": "integer", "example": 20 },
                  "Descripcion": { "type": "string", "example": "Órgano vital" },
                  "Funcion": { "type": "string", "example": "Bombear sangre" },
                  "Fecha_Registro": { "type": "string", "format": "date", "example": "2026-03-10" }
                }
              }
            }
          }
        },
        "responses": { "201": { "description": "Creado" } }
      }
    },
    "/gerencia/organos/{id}": {
      "get": { "summary": "Obtener órgano", "tags": ["Orgános"], "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }], "responses": { "200": { "description": "OK" } } },
      "put": {
        "summary": "Actualizar órgano",
        "tags": ["Orgános"],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "Nombre": { "type": "string", "example": "Corazón" },
                  "Sistema_Aparato": { "type": "string", "example": "Circulatorio" },
                  "Requisitos": { "type": "string", "example": "Condición A" },
                  "Stock": { "type": "integer", "example": 30 },
                  "Descripcion": { "type": "string", "example": "Órgano vital" },
                  "Funcion": { "type": "string", "example": "Bombear sangre" }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "Actualizado" } }
      },
      "delete": { "summary": "Eliminar órgano", "tags": ["Orgános"], "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }], "responses": { "200": { "description": "Eliminado" } } }
    },
    "/gerencia/areas": {
      "get": { "summary": "Listar áreas", "tags": ["Áreas"], "responses": { "200": { "description": "OK" } } },
      "post": {
        "summary": "Crear área",
        "tags": ["Áreas"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["nombre", "descripcion"],
                "properties": {
                  "nombre": { "type": "string", "example": "Emergencias" },
                  "descripcion": { "type": "string", "example": "Área de atención inmediata" },
                  "ubicacion_id": { "type": ["integer", "null"], "example": null },
                  "personal_id_responsable": { "type": ["integer", "null"], "example": null },
                  "area_superior_id": { "type": ["integer", "null"], "example": null },
                  "estatus_operacion": { "type": "string", "example": "Activo" },
                  "total_empleados": { "type": "integer", "example": 20 }
                }
              }
            }
          }
        },
        "responses": { "201": { "description": "Creada" } }
      }
    },
    "/gerencia/areas/{id}": {
      "put": {
        "summary": "Actualizar área",
        "tags": ["Áreas"],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "nombre": { "type": "string", "example": "Emergencias" },
                  "descripcion": { "type": "string", "example": "Área de atención inmediata" },
                  "estatus_operacion": { "type": "string", "example": "Mantenimiento" },
                  "total_empleados": { "type": "integer", "example": 25 }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "Actualizada" } }
      },
      "delete": { "summary": "Eliminar (lógico) área", "tags": ["Áreas"], "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }], "responses": { "200": { "description": "Eliminada" } } }
    },
    "/gerencia/aprobaciones/pendientes": {
      "get": { "summary": "Ver solicitudes pendientes", "tags": ["Aprobaciones"], "responses": { "200": { "description": "Lista" } } }
    },
    "/gerencia/aprobaciones/historial": {
      "get": { "summary": "Ver historial de aprobaciones", "tags": ["Aprobaciones"], "responses": { "200": { "description": "Lista" } } }
    },
    "/gerencia/aprobaciones": {
      "post": {
        "summary": "Crear solicitud de aprobación",
        "tags": ["Aprobaciones"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["personal_id", "servicio_id", "servicio_descripcion"],
                "properties": {
                  "personal_id": { "type": "integer", "example": 123 },
                  "servicio_id": { "type": "integer", "example": 45 },
                  "servicio_descripcion": { "type": "string", "example": "Requiere aprobación para cirugía" }
                }
              }
            }
          }
        },
        "responses": { "201": { "description": "Creada" } }
      }
    },
    "/gerencia/aprobaciones/{id}": {
      "patch": {
        "summary": "Procesar aprobacion",
        "tags": ["Aprobaciones"],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["decision"],
                "properties": {
                  "decision": { "type": "string", "enum": ["Aprobado", "Rechazado"], "example": "Aprobado" }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "Procesada" } }
      }
    },
    "/gerencia/accesos": {
      "get": { "summary": "Historial accesos", "tags": ["Accesos"], "responses": { "200": { "description": "OK" } } },
      "post": {
        "summary": "Registrar acceso",
        "tags": ["Accesos"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["persona_id", "espacio_id", "tipo", "autoriza_id"],
                "properties": {
                  "persona_id": { "type": "integer", "example": 101 },
                  "espacio_id": { "type": "integer", "example": 5 },
                  "tipo": { "type": "string", "example": "Entrada" },
                  "autoriza_id": { "type": "integer", "example": 12 }
                }
              }
            }
          }
        },
        "responses": { "201": { "description": "Registrado" } }
      }
    },
    "/gerencia/accesos/persona/{id}": {
      "get": { "summary": "Accesos por persona", "tags": ["Accesos"], "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }], "responses": { "200": { "description": "OK" } } }
    },
    "/gerencia/accesos/fechas": {
      "get": { "summary": "Accesos por rango fechas", "tags": ["Accesos"], "responses": { "200": { "description": "OK" } } }
    },
    "/gerencia/tipos": {
      "get": { "summary": "Listar tipos patología", "tags": ["Patología Tipos"], "responses": { "200": { "description": "OK" } } },
      "post": {
        "summary": "Crear tipo patología",
        "tags": ["Patología Tipos"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["nombre", "descripcion"],
                "properties": {
                  "nombre": { "type": "string", "example": "Oncológica" },
                  "descripcion": { "type": "string", "example": "Tipo relacionado con cáncer" }
                }
              }
            }
          }
        },
        "responses": { "201": { "description": "Creado" } }
      }
    },
    "/gerencia/tipos/{id}/clasificacion": {
      "get": { "summary": "Obtener clasificación por tipo", "tags": ["Patología Tipos"], "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }], "responses": { "200": { "description": "OK" } } }
    },
    "/gerencia/reporte-roles": {
      "get": { "summary": "Reporte de roles", "tags": ["Vistas"], "responses": { "200": { "description": "OK" } } }
    },
    "/gerencia/inventario": {
      "get": { "summary": "Listar inventario órganos", "tags": ["Inventario"], "responses": { "200": { "description": "OK" } } },
      "post": {
        "summary": "Agregar inventario órgano",
        "tags": ["Inventario"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["Organo_ID", "Fecha_Expiracion", "Estado"],
                "properties": {
                  "Organo_ID": { "type": "integer", "example": 1 },
                  "Fecha_Expiracion": { "type": "string", "format": "date", "example": "2026-12-31" },
                  "Estado": { "type": "string", "example": "Disponible" },
                  "Raza": { "type": "string", "example": "N/A" },
                  "Grupo_Sanguineo": { "type": "string", "example": "O+" },
                  "Observaciones": { "type": "string", "example": "Unidad de prueba" }
                }
              }
            }
          }
        },
        "responses": { "201": { "description": "Creado" } }
      }
    },
    "/gerencia/inventario/{id}": {
      "put": {
        "summary": "Actualizar inventario órgano",
        "tags": ["Inventario"],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "Organo_ID": { "type": "integer", "example": 1 },
                  "Fecha_Expiracion": { "type": "string", "format": "date", "example": "2027-01-01" },
                  "Estado": { "type": "string", "example": "Disponible" },
                  "Raza": { "type": "string", "example": "N/A" },
                  "Grupo_Sanguineo": { "type": "string", "example": "AB-" },
                  "Observaciones": { "type": "string", "example": "Refrigerado" }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "Actualizado" } }
      },
      "delete": { "summary": "Eliminar inventario órgano", "tags": ["Inventario"], "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }], "responses": { "200": { "description": "Eliminado" } } }
    },
    "/gerencia/mongo/quejas": {
      "post": {
        "summary": "Registrar Queja/Sugerencia en MongoDB",
        "tags": ["Gerencia NoSQL"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "folio": { "type": "string", "example": "QUE-001" },
                  "tipo": { "type": "string", "enum": ["queja", "sugerencia"], "example": "queja" },
                  "prioridad": { "type": "string", "example": "alta" },
                  "descripcion": { "type": "string", "example": "Falta de insumos en piso 2" },
                  "persona_fisica": { "type": "object", "properties": { "id": { "type": "integer", "example": 10 }, "nombre": { "type": "string", "example": "Jonathan" } } },
                  "departamento": { "type": "object", "properties": { "id": { "type": "integer", "example": 5 }, "nombre": { "type": "string", "example": "Gerencia" } } }
                }
              }
            }
          }
        },
        "responses": { "201": { "description": "Guardado en MongoDB" } }
      },
      "get": {
        "summary": "Obtener todas las Quejas/Sugerencias",
        "tags": ["Gerencia NoSQL"],
        "responses": {
          "200": {
            "description": "Lista de quejas obtenida",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "cantidad": { "type": "integer", "example": 5 },
                    "data": { "type": "array" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/gerencia/mongo/quejas/{id}": {
      "get": {
        "summary": "Obtener Queja por ID",
        "tags": ["Gerencia NoSQL"],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Queja encontrada" }, "404": { "description": "Queja no encontrada" } }
      },
      "put": {
        "summary": "Actualizar Queja",
        "tags": ["Gerencia NoSQL"],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "estatus": { "type": "string", "example": "en_proceso" },
                  "prioridad": { "type": "string", "example": "alta" }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "Queja actualizada" }, "404": { "description": "Queja no encontrada" } }
      },
      "delete": {
        "summary": "Eliminar Queja",
        "tags": ["Gerencia NoSQL"],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Queja eliminada" }, "404": { "description": "Queja no encontrada" } }
      }
    },
    "/gerencia/mongo/aprobaciones/limpiar": {
      "delete": {
        "summary": "Vaciar la colección de aprobaciones",
        "tags": ["Mongo Seeder"],
        "responses": {
          "200": {
            "description": "Colección limpiada exitosamente",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": { "type": "string", "example": "Colección de Aprobaciones limpiada exitosamente." },
                    "deletedCount": { "type": "integer", "example": 100 }
                  }
                }
              }
            }
          },
          "500": { "description": "Error interno del servidor" }
        }
      }
    },
    "/gerencia/mongo/aprobaciones": {
      "post": {
        "summary": "Registrar Aprobación en MongoDB",
